{
	"name": "bat",
	"version": "1.0.3",
	"private": true,
	"packageManager": "pnpm@10.28.1",
	"workspaces": ["packages/*"],
	"scripts": {
		"dev": "turbo dev --filter=@bat/dashboard",
		"dev:all": "turbo dev",
		"build": "turbo build",
		"typecheck": "turbo typecheck",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --write .",
		"test": "turbo test",
		"security": "bun run scripts/run-security.ts",
		"prepare": "husky"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "workerd", "sharp"]
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"husky": "^9.1.0",
		"lint-staged": "^16.4.0",
		"picomatch": "^4.0.4",
		"turbo": "^2.5.0",
		"typescript": "^5.8.2"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": ["biome check --error-on-warnings --no-errors-on-unmatched"]
	},
	"overrides": {
		"undici": ">=7.24.0"
	}
}
