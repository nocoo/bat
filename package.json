{
	"name": "bat",
	"version": "2.1.0",
	"private": true,
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev --parallel --filter=!@bat/cli",
		"release": "bun scripts/release.ts",
		"build": "turbo build --filter=@bat/ui",
		"deploy": "turbo build --filter=@bat/ui && cd packages/worker && npx wrangler deploy --env production",
		"typecheck": "turbo typecheck",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --write .",
		"test": "turbo test && cd probe && cargo test --quiet",
		"test:unit:coverage": "bash scripts/check-coverage.sh",
		"test:e2e:pw": "cd packages/ui && bunx playwright test",
		"gate:routes": "bun run scripts/check-route-coverage.ts",
		"gate:pages": "bun run scripts/check-page-coverage.ts",
		"gate:security": "bun run scripts/run-security.ts",
		"prepare": "husky"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"better-sqlite3",
		"esbuild",
		"workerd"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/better-sqlite3": "^7.6.13",
		"@vitest/coverage-v8": "4.1.10",
		"better-sqlite3": "^12.11.1",
		"husky": "^9.1.0",
		"lint-staged": "^17.0.8",
		"picomatch": "^4.0.5",
		"turbo": "2.10.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": [
			"biome check --error-on-warnings --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"postcss": "^8.5.16"
	},
	"overrides": {
		"esbuild": "0.28.1",
		"undici": "^7.28.0",
		"ws": "8.21.0"
	}
}
