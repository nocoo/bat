{
	"name": "bat",
	"version": "1.0.4",
	"private": true,
	"packageManager": "bun@1.3.11",
	"workspaces": ["packages/*"],
	"scripts": {
		"dev": "turbo run dev --parallel",
		"build": "turbo build --filter=@bat/ui",
		"deploy": "turbo build --filter=@bat/ui && cd packages/worker && npx wrangler deploy --env production",
		"typecheck": "turbo typecheck",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --write .",
		"test": "turbo test",
		"test:unit:coverage": "turbo test:unit:coverage",
		"test:e2e:pw": "cd packages/ui && bunx playwright test",
		"prepare": "husky"
	},
	"trustedDependencies": ["@biomejs/biome", "esbuild", "workerd"],
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"husky": "^9.1.0",
		"lint-staged": "^16.4.0",
		"picomatch": "^4.0.4",
		"turbo": "^2.5.0",
		"typescript": "^5.8.2"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": ["biome check --error-on-warnings --no-errors-on-unmatched"]
	},
	"overrides": {
		"undici": ">=7.24.0"
	}
}
